# Persistent PostgreSQL database (use the pooled URL supplied by Neon/Vercel).
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_POOL_MAX=1
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_IDLE_TIMEOUT_SECONDS=20

# Authentication and canonical Steam OpenID origin.
SESSION_SECRET=replace-with-at-least-32-random-bytes
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_LOGIN=admin
ADMIN_PASSWORD=replace-with-a-long-random-password
STEAM_API_KEY=

# Public English CS2 metadata.
CSGO_API_BASE_URL=https://raw.githubusercontent.com/ByMykel/CSGO-API/main/public/api/en/
CSGO_API_CACHE_TTL_SECONDS=21600

# Public Skinport market prices. The documented items endpoint requires no API key.
SKINPORT_PRICE_CURRENCY=USD
SKINPORT_PRICE_CACHE_TTL_SECONDS=300
